{
    "app-id": "app.polychromatic.controller",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "polychromatic-controller",
    "base": "com.riverbankcomputing.PyQt.BaseApp",
    "base-version": "6.10",
    "rename-icon": "polychromatic",
    "rename-desktop-file": "polychromatic.desktop",
    "cleanup-commands": [
        "/app/cleanup-BaseApp.sh"
    ],
    "finish-args": [
        "--env=QTWEBENGINEPROCESS_PATH=/app/bin/QtWebEngineProcess",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--share=ipc",
        "--share=network",
        "--talk-name=org.razer",
        "--device=dri"
    ],
    "modules": [
        "python3-modules.json",
        {
            "name": "openrazer-pylib",
            "no-autogen": true,
            "make-args": [
                "PREFIX=/app",
                "daemon_install",
                "python_library_install"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/openrazer/openrazer/releases/download/v3.12.3/openrazer-3.12.3.tar.xz",
